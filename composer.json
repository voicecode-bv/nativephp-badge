{
    "name": "voicecode-bv/native-badge",
    "description": "Set the app icon badge counter from JS/PHP for NativePHP Mobile",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Voicecode BV"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "VoicecodeBv\\NativeBadge\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VoicecodeBv\\NativeBadge\\NativeBadgeServiceProvider"
            ],
            "aliases": {
                "NativeBadge": "VoicecodeBv\\NativeBadge\\Facades\\NativeBadge"
            }
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    }
}
